# horix-erp configuration — Copiar a config.env y ajustar

MODE=test                    # test | prod

# Ports
LAUNCHER_PORT=3002
HORIX_PORT=3000
DOCFLOW_PORT=3100

# Install paths
INSTALL_DIR=/opt/horix-platform

# Submodules (deploy uses git pull --recurse-submodules)
LAUNCHER_REPO=https://github.com/Kernel-Panic92/horix-launcher.git
HORIX_REPO=https://github.com/Kernel-Panic92/horix-api.git
DOCFLOW_REPO=https://github.com/Kernel-Panic92/docflow-api.git
