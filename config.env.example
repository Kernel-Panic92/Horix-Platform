# ── horix-platform configuration ──
# Copiar a config.env y ajustar

MODE=test                    # test | prod

# Domain / hosts (test → subdominios, prod → mismo dominio)
SHELL_HOST=shell.dev.local
HORIX_HOST=horix.dev.local
DOCFLOW_HOST=docflow.dev.local

# Ports (nginx external)
SHELL_PORT=8443
HORIX_PORT=8444
DOCFLOW_PORT=8445

# Internal ports (apps)
HORIX_INTERNAL_PORT=3000
DOCFLOW_INTERNAL_PORT=3100
MCP_GATEWAY_PORT=3002

# Repos
HORIX_REPO=https://github.com/Kernel-Panic92/Horix.git
DOCFLOW_REPO=https://github.com/Kernel-Panic92/docflow.git

# Install paths
INSTALL_DIR=/opt/horix-platform

# Auth (JWT compartido entre módulos para SSO)
JWT_SECRET=generado_por_install.sh
